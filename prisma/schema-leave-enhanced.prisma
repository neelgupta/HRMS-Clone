// ========================================
// ENHANCED LEAVE & TIME-OFF MANAGEMENT SCHEMA
// Add to prisma/schema.prisma
// ========================================

// ========================================
// LEAVE TYPES & CONFIGURATION
// ========================================

// Leave Type Configuration (company-specific)
model LeaveTypeConfig {
  id              String        @id @default(uuid())
  companyId       String
  company         Company       @relation(fields: [companyId], references: [id])
  
  name            String        // e.g., "Casual Leave", "Sick Leave"
  code            String        // e.g., "CL", "SL", "EL"
  type            LeaveCategory // CASUAL, SICK, PRIVILEGE, MATERNITY, PATERNITY, BEREAVEMENT, UNPAID, COMP_OFF
  
  // Annual quota
  annualDays      Int           @default(0) // 0 means not applicable
  isActive        Boolean       @default(true)
  
  // Accrual settings
  accrualType     AccrualType   @default(YEARLY) // MONTHLY, YEARLY
  accrualRate     Float         @default(0) // Days per month if monthly
  
  // Rules
  maxConsecutive  Int           @default(0) // Max consecutive days
  minNoticeDays   Int           @default(0) // Days notice required
  canApplyHalfDay Boolean       @default(true)
  maxHalfDaysPerYear Int         @default(0)
  
  // Gender-specific
  genderSpecific  Gender?       // MALE, FEMALE, null = all
  
  // Carry forward
  allowCarryForward Boolean     @default(false)
  maxCarryForward  Int           @default(0)
  
  // Encashment
  allowEncashment  Boolean       @default(false)
  maxEncashDays    Int           @default(0)
  
  // Expiry
  expiryDays       Int           @default(0) // Days until expiry (0 = no expiry)
  
  sortOrder        Int           @default(0)
  
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@unique([companyId, code])
  @@index([companyId])
  @@map("leave_type_configs")
}

enum LeaveCategory {
  CASUAL
  SICK
  PRIVILEGE
  MATERNITY
  PATERNITY
  BEREAVEMENT
  UNPAID
  COMP_OFF
  WORK_FROM_HOME
}

enum AccrualType {
  MONTHLY
  YEARLY
}

// ========================================
// LEAVE POLICY (Company-wide)
// ========================================

model LeavePolicy {
  id                    String        @id @default(uuid())
  companyId             String        @unique
  company               Company       @relation(fields: [companyId], references: [id])
  
  // Default approval workflow
  approvalLevel1       ApprovalRole  @default(MANAGER) // MANAGER, HR, BOTH
  approvalLevel2       ApprovalRole? // Optional second level
  managerApprovalDays  Int           @default(2) // Days for manager to respond
  hrApprovalDays       Int           @default(3) // Days for HR to respond
  
  // Leave encoding & year transition
  encashmentStartMonth Int           @default(1) // Month when encashment window opens
  encashmentEndMonth   Int           @default(3) // Month when encashment window closes
  
  // Carry forward processing
  processCarryForward  Boolean       @default(true)
  carryForwardDeadline DateTime?     // Deadline to apply for CF
  
  // Auto-approval
  allowAutoApproval    Boolean       @default(false)
  autoApprovalDaysThreshold Int      @default(0) // Auto-approve if balance > threshold
  
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@map("leave_policies")
}

enum ApprovalRole {
  MANAGER
  HR
  BOTH
}

// ========================================
// LEAVE APPLICATION (with half-day support)
// ========================================

model LeaveApplication {
  id                String          @id @default(uuid())
  employeeId        String
  employee          Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  companyId         String
  company           Company         @relation(fields: [companyId], references: [id])
  
  leaveTypeId       String
  leaveTypeConfig   LeaveTypeConfig @relation(fields: [leaveTypeId], references: [id])
  
  // Leave details
  startDate         DateTime        @db.Date
  endDate           DateTime        @db.Date
  startSession      SessionType     @default(FULL_DAY) // FULL_DAY, FIRST_HALF, SECOND_HALF
  endSession        SessionType     @default(FULL_DAY)
  totalDays         Float           // 0.5 for half day, 1 for full day
  
  reason            String?
  attachmentUrl     String?
  
  // Status & workflow
  status            LeaveStatus     @default(PENDING)
  
  // Level 1 approval (Manager)
  level1Status      ApprovalStatus  @default(PENDING)
  level1ReviewedBy  String?
  level1ReviewedAt  DateTime?
  level1Remarks     String?
  
  // Level 2 approval (HR - if required)
  level2Status      ApprovalStatus? 
  level2ReviewedBy  String?
  level2ReviewedAt  DateTime?
  level2Remarks     String?
  
  // Current approver info
  currentApproverLevel Int           @default(1) // 1 = manager, 2 = HR
  approverId         String?        // User ID of current approver
  
  // Cancellation
  isCancelled       Boolean         @default(false)
  cancelledAt        DateTime?
  cancelledBy        String?
  
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([employeeId, startDate])
  @@index([companyId])
  @@index([employeeId])
  @@index([status])
  @@index([leaveTypeId])
  @@map("leave_applications")
}

enum SessionType {
  FULL_DAY
  FIRST_HALF
  SECOND_HALF
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  MODIFICATION_REQUESTED
}

// ========================================
// LEAVE BALANCE (with accrual tracking)
// ========================================

model LeaveBalance {
  id                String          @id @default(uuid())
  employeeId        String
  employee          Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  companyId         String
  
  leaveTypeId       String
  leaveTypeConfig   LeaveTypeConfig @relation(fields: [leaveTypeId], references: [id])
  
  year              Int             // Calendar year
  month             Int?            // For monthly accrual tracking
  
  // Allocations
  allocatedDays     Float           @default(0) // Total allocated for year
  accruedDays       Float           @default(0) // Accrued so far (for monthly)
  carriedForward    Float           @default(0) // From previous year
  
  // Usage
  usedDays          Float           @default(0)
  pendingDays       Float           @default(0)
  availableDays     Float           // Computed: allocated + accrued + CF - used - pending
  
  // Encashment
  encashedDays      Float           @default(0)
  
  // Expiry tracking
  expiredDays       Float           @default(0)
  lastAccruedAt     DateTime?
  
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@unique([employeeId, year, leaveTypeId])
  @@index([employeeId])
  @@index([companyId])
  @@map("leave_balances")
}

// ========================================
// COMPENSATORY OFF (COMP-OFF)
// ========================================

model CompOffRequest {
  id                String        @id @default(uuid())
  companyId         String
  company           Company       @relation(fields: [companyId], references: [id])
  
  employeeId        String
  employee          Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  // Work details
  workDate          DateTime      @db.Date // Date worked (holiday/weekend)
  workSession       SessionType   @default(FULL_DAY)
  
  // Comp-off details
  expiryDate        DateTime?     // When comp-off expires
  isUsed            Boolean       @default(false)
  usedOnDate        DateTime?     // When comp-off was utilized
  
  reason            String?
  attachmentUrl     String?
  approvedBy        String?
  approvedAt        DateTime?
  
  status            CompOffStatus @default(PENDING)
  
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@unique([employeeId, workDate])
  @@index([companyId])
  @@index([employeeId])
  @@map("comp_off_requests")
}

enum CompOffStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
  USED
  CANCELLED
}

// Comp-off balance
model CompOffBalance {
  id                String   @id @default(uuid())
  employeeId        String
  employee          Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  companyId         String
  
  earnedDays        Float    @default(0) // Total earned
  usedDays          Float    @default(0) // Total used
  availableDays     Float    // Computed
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([employeeId])
  @@index([employeeId])
  @@map("comp_off_balances")
}

// ========================================
// HOLIDAYS (with location support)
// ========================================

model Holiday {
  id              String        @id @default(uuid())
  companyId       String
  company         Company       @relation(fields: [companyId], references: [id])
  
  name            String
  date            DateTime      @db.Date
  description     String?
  
  // Location-specific
  branchId        String?
  branch          Branch?       @relation(fields: [branchId], references: [id])
  
  isOptional      Boolean       @default(false) // Optional holiday
  isRecurring     Boolean       @default(true) // Repeats every year
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([companyId, date, branchId])
  @@index([companyId])
  @@index([branchId])
  @@map("holidays")
}

// ========================================
// LEAVE COMMENTS & COMMUNICATION
// ========================================

model LeaveComment {
  id          String   @id @default(uuid())
  applicationId String
  application LeaveApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  
  comment     String
  isInternal  Boolean  @default(false) // Internal note (not visible to employee)
  
  createdAt   DateTime @default(now())

  @@index([applicationId])
  @@map("leave_comments")
}

// ========================================
// LEAVE NOTIFICATIONS
// ========================================

model LeaveNotification {
  id            String          @id @default(uuid())
  companyId     String
  
  employeeId    String // Recipient
  type          NotificationType
  
  title         String
  message       String
  
  relatedType   String? // "LeaveApplication", "LeaveBalance"
  relatedId     String?
  
  isRead        Boolean         @default(false)
  readAt        DateTime?
  
  createdAt     DateTime        @default(now())

  @@index([employeeId])
  @@index([companyId])
  @@map("leave_notifications")
}

enum NotificationType {
  LEAVE_APPLIED
  LEAVE_APPROVED
  LEAVE_REJECTED
  LEAVE_MODIFICATION_REQUESTED
  LEAVE_CANCELLED
  BALANCE_LOW
  COMP_OFF_EARNED
  COMP_OFF_EXPIRING
}

// ========================================
// LEAVE APPROVAL HISTORY
// ========================================

model LeaveApprovalHistory {
  id            String   @id @default(uuid())
  applicationId String
  application   LeaveApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  
  approverId    String
  level         Int      // 1 or 2
  
  action        String   // APPROVED, REJECTED, MODIFICATION_REQUESTED
  comments      String?
  
  createdAt     DateTime @default(now())

  @@index([applicationId])
  @@map("leave_approval_history")
}