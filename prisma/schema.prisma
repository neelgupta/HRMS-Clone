generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id                   String                @id @default(uuid())
  name                 String
  status               CompanyStatus         @default(PENDING)
  logoUrl              String?
  iconUrl              String?
  industry             String?
  registrationNumber   String?
  panNumber            String?
  tanNumber            String?
  gstNumber            String?
  startDate            DateTime?
  fiscalYearStart      DateTime?
  fiscalYearEnd        DateTime?
  primaryEmail         String?
  primaryPhone         String?
  website              String?
  setupCompleted       Boolean               @default(false)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  attendancePolicy     AttendancePolicy?
  auditLogs            AuditLog[]
  bankDetail           BankDetail?
  branches             Branch[]
  compOffBalances      CompOffBalance[]
  compOffRequests      CompOffRequest[]
  addresses            CompanyAddress[]
  departments          Department[]
  designations         Designation[]
  employeeCustomFields EmployeeCustomField[]
  employees            Employee[]
  generalSetting       GeneralSetting?
  holidays             Holiday[]
  leaveApplications    LeaveApplication[]
  leaveBalances        LeaveBalance[]
  leaveHolidays        LeaveHoliday[]
  leaveNotifications   LeaveNotification[]
  leavePolicies        LeavePolicy?
  leaveTypeConfigs     LeaveTypeConfig[]
  shifts               Shift[]
  users                User[]
  salaryComponents     SalaryComponent[]
  salaryStructures     SalaryStructure[]
  taxDeclarations      TaxDeclaration[]
  payrollRuns          PayrollRun[]
  loans                Loan[]
  reimbursements       Reimbursement[]
  payrollSettings      PayrollSetting?
  employeeTaxConfigs   EmployeeTaxConfig[]
  ptSlabs              ProfessionalTaxSlab[]
  fullFinalSettlements FullFinalSettlement[]

  @@map("companies")
}

model User {
  id                   String                 @id @default(uuid())
  name                 String
  email                String                 @unique
  phone                String
  password             String
  role                 Role                   @default(HR_ADMIN)
  status               UserStatus             @default(INACTIVE)
  companyId            String
  branchId             String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  employeeId           String?                @unique
  leaveApprovalHistory LeaveApprovalHistory[]
  leaveComments        LeaveComment[]
  resetTokens          PasswordResetToken[]
  payrollPin           PayrollPINConfig?
  branch               Branch?                @relation(fields: [branchId], references: [id])
  company              Company                @relation(fields: [companyId], references: [id])
  employee             Employee?              @relation(fields: [employeeId], references: [id])

  @@map("users")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@map("password_reset_tokens")
}

model CompanyAddress {
  id           String      @id @default(uuid())
  companyId    String
  type         AddressType
  label        String?
  addressLine1 String
  addressLine2 String?
  city         String
  state        String
  country      String
  pincode      String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  company      Company     @relation(fields: [companyId], references: [id])

  @@map("company_addresses")
}

model Branch {
  id           String     @id @default(uuid())
  companyId    String
  name         String
  contactEmail String?
  contactPhone String?
  addressLine1 String
  addressLine2 String?
  city         String
  state        String
  country      String
  pincode      String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  company      Company    @relation(fields: [companyId], references: [id])
  employees    Employee[]
  holidays     Holiday[]
  users        User[]

  @@map("branches")
}

model BankDetail {
  id                String   @id @default(uuid())
  companyId         String   @unique
  bankName          String
  accountHolderName String
  accountNumber     String
  ifscCode          String
  branchName        String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  company           Company  @relation(fields: [companyId], references: [id])

  @@map("bank_details")
}

model GeneralSetting {
  id                 String       @id @default(uuid())
  companyId          String       @unique
  currency           String       @default("INR")
  dateFormat         String       @default("DD/MM/YYYY")
  timeZone           String       @default("Asia/Kolkata")
  workweek           WorkweekType @default(MON_FRI)
  holidayList        DateTime[]
  emailNotifications Boolean      @default(true)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  company            Company      @relation(fields: [companyId], references: [id])

  @@map("general_settings")
}

model EmployeeCustomField {
  id        String                     @id @default(uuid())
  companyId String
  fieldName String
  fieldType CustomFieldType
  required  Boolean                    @default(false)
  options   String[]
  sortOrder Int                        @default(0)
  createdAt DateTime                   @default(now())
  updatedAt DateTime                   @updatedAt
  values    EmployeeCustomFieldValue[]
  company   Company                    @relation(fields: [companyId], references: [id])

  @@map("employee_custom_fields")
}

model Department {
  id          String     @id @default(uuid())
  companyId   String
  name        String
  code        String
  description String?
  headId      String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  company     Company    @relation(fields: [companyId], references: [id])
  employees   Employee[]

  @@unique([companyId, code])
  @@index([companyId])
  @@map("departments")
}

model Designation {
  id          String     @id @default(uuid())
  companyId   String
  name        String
  code        String
  level       Int        @default(1)
  description String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  company     Company    @relation(fields: [companyId], references: [id])
  employees   Employee[]

  @@unique([companyId, code])
  @@index([companyId])
  @@map("designations")
}

model Employee {
  id                       String                     @id @default(uuid())
  companyId                String
  branchId                 String?
  departmentId             String?
  designationId            String?
  reportingManagerId       String?
  employeeCode             String                     @unique
  firstName                String
  lastName                 String
  email                    String                     @unique
  phone                    String?
  photoUrl                 String?
  dateOfBirth              DateTime?
  gender                   Gender?
  maritalStatus            MaritalStatus?
  bloodGroup               String?
  dateOfJoining            DateTime?
  probationEndDate         DateTime?
  dateOfLeaving            DateTime?
  employmentType           EmploymentType             @default(FULL_TIME)
  employmentStatus         EmploymentStatus           @default(PROBATION)
  emergencyContactName     String?
  emergencyContactPhone    String?
  emergencyContactRelation String?
  presentAddressLine1      String?
  presentAddressLine2      String?
  presentCity              String?
  presentState             String?
  presentCountry           String?
  presentPincode           String?
  permanentAddressLine1    String?
  permanentAddressLine2    String?
  permanentCity            String?
  permanentState           String?
  permanentCountry         String?
  permanentPincode         String?
  bankAccountHolderName    String?
  bankAccountNumber        String?
  bankName                 String?
  bankBranchName           String?
  bankIfscCode             String?
  panNumber                String?
  aadharNumber             String?
  pfNumber                 String?
  pfUAN                    String?
  esiNumber                String?
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt
  isDeleted                Boolean                    @default(false)
  companyEmail             String?  @unique
  userEmail                String?
  userPassword             String?
  attendances              Attendance[]
  compOffBalance           CompOffBalance?
  compOffRequests          CompOffRequest[]
  documents                Document[]
  customFieldValues        EmployeeCustomFieldValue[]
  education                EmployeeEducation[]
  workHistory              EmployeeWorkHistory[]
  branch                   Branch?                    @relation(fields: [branchId], references: [id])
  company                  Company                    @relation(fields: [companyId], references: [id])
  department               Department?                @relation(fields: [departmentId], references: [id])
  designation              Designation?               @relation(fields: [designationId], references: [id])
  reportingManager         Employee?                  @relation("ManagerReports", fields: [reportingManagerId], references: [id])
  reports                  Employee[]                 @relation("ManagerReports")
  leaveApplications        LeaveApplication[]
  leaveBalances            LeaveBalance[]
  shiftAssignments         ShiftAssignment[]
  user                     User?
  salaryStructures         SalaryStructure[]
  taxDeclarations          TaxDeclaration[]
  payrollItems             PayrollItem[]
  loans                    Loan[]
  reimbursements           Reimbursement[]
  pfRecords                PFRecord[]
  esiRecords               ESIRecord[]
  tdsRecords               TDSRecord[]
  taxConfig                EmployeeTaxConfig?
  fullFinalSettlement      FullFinalSettlement?

  @@index([companyId])
  @@index([branchId])
  @@index([departmentId])
  @@index([designationId])
  @@index([reportingManagerId])
  @@map("employees")
}

model EmployeeEducation {
  id            String   @id @default(uuid())
  employeeId    String
  degree        String
  institution   String
  yearOfPassing Int?
  percentage    Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("employee_educations")
}

model EmployeeWorkHistory {
  id               String    @id @default(uuid())
  employeeId       String
  companyName      String
  designation      String
  startDate        DateTime
  endDate          DateTime?
  isCurrent        Boolean   @default(false)
  reasonForLeaving String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  employee         Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("employee_work_histories")
}

model EmployeeCustomFieldValue {
  id         String              @id @default(uuid())
  employeeId String
  fieldId    String
  value      String
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  employee   Employee            @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  field      EmployeeCustomField @relation(fields: [fieldId], references: [id])

  @@unique([employeeId, fieldId])
  @@map("employee_custom_field_values")
}

model Document {
  id          String       @id @default(uuid())
  employeeId  String
  type        DocumentType
  name        String
  fileUrl     String
  fileSize    Int?
  mimeType    String?
  expiryDate  DateTime?
  version     Int          @default(1)
  parentId    String?
  isExpired   Boolean      @default(false)
  accessRoles Role[]
  createdBy   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  employee    Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  parent      Document?    @relation("DocumentVersion", fields: [parentId], references: [id])
  versions    Document[]   @relation("DocumentVersion")

  @@index([employeeId])
  @@index([expiryDate])
  @@index([type])
  @@map("documents")
}

model AuditLog {
  id         String   @id @default(uuid())
  companyId  String
  userId     String
  action     String
  entityType String
  entityId   String?
  oldValues  Json?
  newValues  Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  company    Company  @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

model Shift {
  id               String            @id @default(uuid())
  companyId        String
  name             String
  code             String
  startTime        String
  endTime          String
  gracePeriodMins  Int               @default(0)
  halfDayHours     Float             @default(4)
  minWorkingHours  Float             @default(8)
  isFlexible       Boolean           @default(false)
  isNightShift     Boolean           @default(false)
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  attendances      Attendance[]
  shiftAssignments ShiftAssignment[]
  company          Company           @relation(fields: [companyId], references: [id])

  @@unique([companyId, code])
  @@index([companyId])
  @@map("shifts")
}

model ShiftAssignment {
  id            String    @id @default(uuid())
  employeeId    String
  shiftId       String
  effectiveFrom DateTime
  effectiveTo   DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  employee      Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shift         Shift     @relation(fields: [shiftId], references: [id])

  @@unique([employeeId, shiftId, effectiveFrom])
  @@index([employeeId])
  @@index([shiftId])
  @@map("shift_assignments")
}

model Attendance {
  id               String                     @id @default(uuid())
  employeeId       String
  companyId        String
  date             DateTime                   @db.Date
  shiftId          String?
  clockIn          DateTime?
  clockOut         DateTime?
  clockInIp        String?
  clockOutIp       String?
  clockInLocation  Json?
  clockOutLocation Json?
  clockInPhoto     String?
  clockOutPhoto    String?
  totalHours       Float?
  overtimeHours    Float?
  status           AttendanceStatus           @default(PENDING)
  remarks          String?
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
  breakEnd         DateTime?
  breakStart       DateTime?
  totalBreakMins   Int?
  regularizations  AttendanceRegularization[]
  employee         Employee                   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shift            Shift?                     @relation(fields: [shiftId], references: [id])

  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([companyId])
  @@index([date])
  @@map("attendances")
}

model AttendancePolicy {
  id                    String   @id @default(uuid())
  companyId             String   @unique
  allowLateArrival      Boolean  @default(true)
  gracePeriodMins       Int      @default(0)
  allowEarlyDeparture   Boolean  @default(true)
  earlyDepartureMins    Int      @default(0)
  halfDayHours          Float    @default(4)
  minWorkingHours       Float    @default(8)
  allowOvertime         Boolean  @default(false)
  maxOvertimeHoursDay   Float    @default(4)
  deductSalaryForLate   Boolean  @default(false)
  lateArrivalDeductPerc Float    @default(0)
  requirePhotoCapture   Boolean  @default(false)
  requireGpsLocation    Boolean  @default(false)
  requireIpRestriction  Boolean  @default(false)
  allowedIps            String[]
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  weeklyOff1            String   @default("SUNDAY")
  weeklyOff2            String?
  company               Company  @relation(fields: [companyId], references: [id])

  @@map("attendance_policies")
}

model AttendanceRegularization {
  id                String               @id @default(uuid())
  attendanceId      String
  employeeId        String
  requestedClockIn  DateTime?
  requestedClockOut DateTime?
  reason            String
  status            RegularizationStatus @default(PENDING)
  reviewedBy        String?
  reviewedAt        DateTime?
  reviewRemarks     String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  attendance        Attendance           @relation(fields: [attendanceId], references: [id], onDelete: Cascade)

  @@index([attendanceId])
  @@index([employeeId])
  @@index([status])
  @@map("attendance_regularizations")
}

model LeaveTypeConfig {
  id                 String             @id @default(uuid())
  companyId          String
  name               String
  code               String
  type               LeaveCategory
  annualDays         Int                @default(0)
  isActive           Boolean            @default(true)
  accrualType        AccrualType        @default(YEARLY)
  accrualRate        Float              @default(0)
  maxConsecutive     Int                @default(0)
  minNoticeDays      Int                @default(0)
  canApplyHalfDay    Boolean            @default(true)
  maxHalfDaysPerYear Int                @default(0)
  genderSpecific     Gender?
  allowCarryForward  Boolean            @default(false)
  maxCarryForward    Int                @default(0)
  allowEncashment    Boolean            @default(false)
  maxEncashDays      Int                @default(0)
  expiryDays         Int                @default(0)
  sortOrder          Int                @default(0)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  leaveApplications  LeaveApplication[]
  leaveBalances      LeaveBalance[]
  company            Company            @relation(fields: [companyId], references: [id])

  @@unique([companyId, code])
  @@index([companyId])
  @@map("leave_type_configs")
}

model LeavePolicy {
  id                        String        @id @default(uuid())
  companyId                 String        @unique
  managerApprovalDays       Int           @default(2)
  createdAt                 DateTime      @default(now())
  updatedAt                 DateTime      @updatedAt
  allowAutoApproval         Boolean       @default(false)
  approvalLevel1            ApprovalRole  @default(MANAGER)
  approvalLevel2            ApprovalRole?
  autoApprovalDaysThreshold Int           @default(0)
  carryForwardDeadline      DateTime?
  encashmentEndMonth        Int           @default(3)
  encashmentStartMonth      Int           @default(1)
  hrApprovalDays            Int           @default(3)
  processCarryForward       Boolean       @default(true)
  company                   Company       @relation(fields: [companyId], references: [id])

  @@map("leave_policies")
}

model LeaveApplication {
  id                   String                 @id @default(uuid())
  employeeId           String
  companyId            String
  leaveType            LeaveType?
  startDate            DateTime               @db.Date
  endDate              DateTime               @db.Date
  totalDays            Float
  reason               String?
  status               LeaveStatus            @default(PENDING)
  attachmentUrl        String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  approverId           String?
  cancelledAt          DateTime?
  cancelledBy          String?
  currentApproverLevel Int                    @default(1)
  endSession           SessionType            @default(FULL_DAY)
  isCancelled          Boolean                @default(false)
  leaveTypeId          String?
  level1Remarks        String?
  level1ReviewedAt     DateTime?
  level1ReviewedBy     String?
  level1Status         ApprovalStatus         @default(PENDING)
  level2Remarks        String?
  level2ReviewedAt     DateTime?
  level2ReviewedBy     String?
  level2Status         ApprovalStatus?
  startSession         SessionType            @default(FULL_DAY)
  company              Company                @relation(fields: [companyId], references: [id])
  employee             Employee               @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveTypeConfig      LeaveTypeConfig?       @relation(fields: [leaveTypeId], references: [id])
  approvalHistory      LeaveApprovalHistory[]
  comments             LeaveComment[]

  @@unique([employeeId, startDate])
  @@index([companyId])
  @@index([employeeId])
  @@index([status])
  @@index([leaveTypeId])
  @@map("leave_applications")
}

model LeaveBalance {
  id              String           @id @default(uuid())
  employeeId      String
  companyId       String
  year            Int
  leaveType       LeaveType?
  usedDays        Float            @default(0)
  pendingDays     Float            @default(0)
  availableDays   Float
  carriedForward  Float            @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  accruedDays     Float            @default(0)
  allocatedDays   Float            @default(0)
  encashedDays    Float            @default(0)
  expiredDays     Float            @default(0)
  lastAccruedAt   DateTime?
  leaveTypeId     String?
  month           Int?
  company         Company          @relation(fields: [companyId], references: [id])
  employee        Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveTypeConfig LeaveTypeConfig? @relation(fields: [leaveTypeId], references: [id])

  @@unique([employeeId, year, leaveTypeId])
  @@unique([employeeId, year, leaveType])
  @@index([employeeId])
  @@index([companyId])
  @@map("leave_balances")
}

model CompOffRequest {
  id            String        @id @default(uuid())
  companyId     String
  employeeId    String
  workDate      DateTime      @db.Date
  workSession   SessionType   @default(FULL_DAY)
  expiryDate    DateTime?
  isUsed        Boolean       @default(false)
  usedOnDate    DateTime?
  reason        String?
  attachmentUrl String?
  approvedBy    String?
  approvedAt    DateTime?
  status        CompOffStatus @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  company       Company       @relation(fields: [companyId], references: [id])
  employee      Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, workDate])
  @@index([companyId])
  @@index([employeeId])
  @@map("comp_off_requests")
}

model CompOffBalance {
  id            String   @id @default(uuid())
  employeeId    String   @unique
  companyId     String
  earnedDays    Float    @default(0)
  usedDays      Float    @default(0)
  availableDays Float
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  company       Company  @relation(fields: [companyId], references: [id])
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("comp_off_balances")
}

model Holiday {
  id          String   @id @default(uuid())
  companyId   String
  name        String
  date        DateTime @db.Date
  description String?
  branchId    String?
  isOptional  Boolean  @default(false)
  isRecurring Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  branch      Branch?  @relation(fields: [branchId], references: [id])
  company     Company  @relation(fields: [companyId], references: [id])

  @@unique([companyId, date, branchId])
  @@index([companyId])
  @@index([branchId])
  @@map("holidays")
}

model LeaveHoliday {
  id         String   @id @default(uuid())
  companyId  String
  name       String
  date       DateTime @db.Date
  isOptional Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  company    Company  @relation(fields: [companyId], references: [id])

  @@unique([companyId, date])
  @@index([companyId])
  @@map("leave_holidays")
}

model LeaveComment {
  id            String           @id @default(uuid())
  applicationId String
  userId        String
  comment       String
  isInternal    Boolean          @default(false)
  createdAt     DateTime         @default(now())
  application   LeaveApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  user          User             @relation(fields: [userId], references: [id])

  @@index([applicationId])
  @@map("leave_comments")
}

model LeaveNotification {
  id          String           @id @default(uuid())
  companyId   String
  employeeId  String
  type        NotificationType
  title       String
  message     String
  relatedType String?
  relatedId   String?
  isRead      Boolean          @default(false)
  readAt      DateTime?
  createdAt   DateTime         @default(now())
  company     Company          @relation(fields: [companyId], references: [id])

  @@index([employeeId])
  @@index([companyId])
  @@map("leave_notifications")
}

model LeaveApprovalHistory {
  id            String           @id @default(uuid())
  applicationId String
  approverId    String
  level         Int
  action        String
  comments      String?
  createdAt     DateTime         @default(now())
  application   LeaveApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  approver      User             @relation(fields: [approverId], references: [id])

  @@index([applicationId])
  @@map("leave_approval_history")
}

enum Role {
  SUPER_ADMIN
  HR_ADMIN
  PAYROLL_MANAGER
  DEPT_MANAGER
  EMPLOYEE
}

enum CompanyStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum UserStatus {
  INACTIVE
  ACTIVE
}

enum AddressType {
  HEAD_OFFICE
  BRANCH
}

enum WorkweekType {
  MON_FRI
  MON_SAT
}

enum CustomFieldType {
  TEXT
  NUMBER
  DATE
  DROPDOWN
  CHECKBOX
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  PROBATION
}

enum EmploymentStatus {
  PROBATION
  CONFIRMED
  TERMINATED
  RESIGNED
  RETIRED
}

enum DocumentType {
  AADHAR_CARD
  PAN_CARD
  PASSPORT
  DRIVING_LICENSE
  VOTER_ID
  BANK_PASSBOOK
  EDUCATION_CERTIFICATE
  EXPERIENCE_LETTER
  OFFER_LETTER
  APPOINTMENT_LETTER
  SALARY_SLIP
  FORM_16
  PF_DOCUMENT
  ESI_DOCUMENT
  PHOTO
  SIGNATURE
  OTHER
}

enum AttendanceStatus {
  PENDING
  PRESENT
  ABSENT
  HALF_DAY
  LATE
  ON_LEAVE
  HOLIDAY
  WEEK_OFF
}

enum RegularizationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LeaveCategory {
  CASUAL
  SICK
  PRIVILEGE
