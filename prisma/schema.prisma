generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id                   String                @id @default(uuid())
  name                 String
  status               CompanyStatus         @default(PENDING)
  logoUrl              String?
  iconUrl              String?
  industry             String?
  registrationNumber   String?
  panNumber            String?
  tanNumber            String?
  gstNumber            String?
  startDate            DateTime?
  fiscalYearStart      DateTime?
  fiscalYearEnd        DateTime?
  primaryEmail         String?
  primaryPhone         String?
  website              String?
  setupCompleted       Boolean               @default(false)
  addresses            CompanyAddress[]
  branches             Branch[]
  bankDetail           BankDetail?
  generalSetting       GeneralSetting?
  employeeCustomFields EmployeeCustomField[]
  employees            Employee[]
  departments          Department[]
  designations         Designation[]
  auditLogs            AuditLog[]
  users                User[]
  shifts               Shift[]
  attendancePolicy     AttendancePolicy?
  leavePolicies        LeavePolicy[]
  leaveTypeConfigs     LeaveTypeConfig[]
  leaveApplications    LeaveApplication[]
  leaveBalances        LeaveBalance[]
  leaveHolidays        LeaveHoliday[]
  holidays             Holiday[]
  compOffRequests      CompOffRequest[]
  compOffBalances      CompOffBalance[]
  leaveNotifications   LeaveNotification[]
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@map("companies")
}

model User {
  id          String               @id @default(uuid())
  name        String
  email       String               @unique
  phone       String
  password    String
  role        Role                 @default(HR_ADMIN)
  status      UserStatus           @default(INACTIVE)
  companyId   String
  branchId    String?
  employeeId  String?              @unique
  branch      Branch?              @relation(fields: [branchId], references: [id])
  company     Company              @relation(fields: [companyId], references: [id])
  employee    Employee?            @relation(fields: [employeeId], references: [id])
  resetTokens PasswordResetToken[]
  leaveComments           LeaveComment[]
  leaveApprovalHistory   LeaveApprovalHistory[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@map("users")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}

model CompanyAddress {
  id           String      @id @default(uuid())
  companyId    String
  company      Company     @relation(fields: [companyId], references: [id])
  type         AddressType
  label        String?
  addressLine1 String
  addressLine2 String?
  city         String
  state        String
  country      String
  pincode      String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@map("company_addresses")
}

model Branch {
  id           String   @id @default(uuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id])
  name         String
  contactEmail String?
  contactPhone String?
  addressLine1 String
  addressLine2 String?
  city         String
  state        String
  country      String
  pincode      String
  users        User[]
  employees    Employee[]
  holidays     Holiday[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("branches")
}

model BankDetail {
  id                String   @id @default(uuid())
  companyId         String   @unique
  company           Company  @relation(fields: [companyId], references: [id])
  bankName          String
  accountHolderName String
  accountNumber     String
  ifscCode          String
  branchName        String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("bank_details")
}

model GeneralSetting {
  id                 String       @id @default(uuid())
  companyId          String       @unique
  company            Company      @relation(fields: [companyId], references: [id])
  currency           String       @default("INR")
  dateFormat         String       @default("DD/MM/YYYY")
  timeZone           String       @default("Asia/Kolkata")
  workweek           WorkweekType @default(MON_FRI)
  holidayList        DateTime[]
  emailNotifications Boolean      @default(true)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@map("general_settings")
}

model EmployeeCustomField {
  id        String          @id @default(uuid())
  companyId String
  company   Company         @relation(fields: [companyId], references: [id])
  fieldName String
  fieldType CustomFieldType
  required  Boolean         @default(false)
  options   String[]
  sortOrder Int             @default(0)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  values    EmployeeCustomFieldValue[]

  @@map("employee_custom_fields")
}

model Department {
  id          String     @id @default(uuid())
  companyId   String
  company     Company    @relation(fields: [companyId], references: [id])
  name        String
  code        String
  description String?
  headId      String?
  isActive    Boolean    @default(true)
  employees   Employee[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([companyId, code])
  @@index([companyId])
  @@map("departments")
}

model Designation {
  id          String     @id @default(uuid())
  companyId   String
  company     Company    @relation(fields: [companyId], references: [id])
  name        String
  code        String
  level       Int        @default(1)
  description String?
  isActive    Boolean    @default(true)
  employees   Employee[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([companyId, code])
  @@index([companyId])
  @@map("designations")
}

model Employee {
  id                 String             @id @default(uuid())
  companyId          String
  company            Company            @relation(fields: [companyId], references: [id])
  branchId           String?
  branch             Branch?            @relation(fields: [branchId], references: [id])
  departmentId       String?
  department         Department?        @relation(fields: [departmentId], references: [id])
  designationId      String?
  designation        Designation?       @relation(fields: [designationId], references: [id])
  reportingManagerId String?
  reportingManager   Employee?          @relation("ManagerReports", fields: [reportingManagerId], references: [id])
  reports           Employee[]         @relation("ManagerReports")

  employeeCode       String             @unique
  firstName          String
  lastName           String
  email              String             @unique
  phone              String?
  photoUrl           String?
  dateOfBirth        DateTime?
  gender             Gender?
  maritalStatus      MaritalStatus?
  bloodGroup          String?
  dateOfJoining      DateTime?
  probationEndDate   DateTime?
  dateOfLeaving       DateTime?
  employmentType      EmploymentType     @default(FULL_TIME)
  employmentStatus    EmploymentStatus   @default(PROBATION)

  emergencyContactName  String?
  emergencyContactPhone String?
  emergencyContactRelation String?

  presentAddressLine1 String?
  presentAddressLine2 String?
  presentCity         String?
  presentState        String?
  presentCountry      String?
  presentPincode      String?

  permanentAddressLine1 String?
  permanentAddressLine2 String?
  permanentCity         String?
  permanentState        String?
  permanentCountry      String?
  permanentPincode      String?

  bankAccountHolderName String?
  bankAccountNumber     String?
  bankName              String?
  bankBranchName        String?
  bankIfscCode          String?

  panNumber            String?
  aadharNumber         String?

  pfNumber             String?
  pfUAN                String?
  esiNumber            String?

  education            EmployeeEducation[]
  workHistory          EmployeeWorkHistory[]
  documents            Document[]
  customFieldValues    EmployeeCustomFieldValue[]
  user                 User?
  attendances          Attendance[]
  shiftAssignments      ShiftAssignment[]
  leaveApplications    LeaveApplication[]
  leaveBalances        LeaveBalance[]
  compOffRequests      CompOffRequest[]
  compOffBalance       CompOffBalance?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([branchId])
  @@index([departmentId])
  @@index([designationId])
  @@index([reportingManagerId])
  @@map("employees")
}

model EmployeeEducation {
  id            String    @id @default(uuid())
  employeeId    String
  employee      Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  degree        String
  institution   String
  yearOfPassing Int?
  percentage    Float?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("employee_educations")
}

model EmployeeWorkHistory {
  id            String    @id @default(uuid())
  employeeId    String
  employee      Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  companyName   String
  designation   String
  startDate     DateTime
  endDate       DateTime?
  isCurrent     Boolean   @default(false)
  reasonForLeaving String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("employee_work_histories")
}

model EmployeeCustomFieldValue {
  id            String            @id @default(uuid())
  employeeId    String
  employee      Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  fieldId       String
  field         EmployeeCustomField @relation(fields: [fieldId], references: [id])
  value         String
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@unique([employeeId, fieldId])
  @@map("employee_custom_field_values")
}

model Document {
  id           String       @id @default(uuid())
  employeeId   String
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type         DocumentType
  name         String
  fileUrl      String
  fileSize     Int?
  mimeType     String?
  expiryDate   DateTime?
  version      Int          @default(1)
  parentId     String?
  parent       Document?    @relation("DocumentVersion", fields: [parentId], references: [id])
  versions     Document[]   @relation("DocumentVersion")
  isExpired    Boolean      @default(false)
  accessRoles  Role[]
  createdBy    String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([employeeId])
  @@index([expiryDate])
  @@index([type])
  @@map("documents")
}

model AuditLog {
  id         String   @id @default(uuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id])
  userId     String
  action     String
  entityType String
  entityId   String?
  oldValues  Json?
  newValues  Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([companyId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

enum Role {
  SUPER_ADMIN
  HR_ADMIN
  PAYROLL_MANAGER
  DEPT_MANAGER
  EMPLOYEE
}

enum CompanyStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum UserStatus {
  INACTIVE
  ACTIVE
}

enum AddressType {
  HEAD_OFFICE
  BRANCH
}

enum WorkweekType {
  MON_FRI
  MON_SAT
}

enum CustomFieldType {
  TEXT
  NUMBER
  DATE
  DROPDOWN
  CHECKBOX
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  PROBATION
}

enum EmploymentStatus {
  PROBATION
  CONFIRMED
  TERMINATED
  RESIGNED
  RETIRED
}

enum DocumentType {
  AADHAR_CARD
  PAN_CARD
  PASSPORT
  DRIVING_LICENSE
  VOTER_ID
  BANK_PASSBOOK
  EDUCATION_CERTIFICATE
  EXPERIENCE_LETTER
  OFFER_LETTER
  APPOINTMENT_LETTER
  SALARY_SLIP
  FORM_16
  PF_DOCUMENT
  ESI_DOCUMENT
  PHOTO
  SIGNATURE
  OTHER
}

model Shift {
  id                String            @id @default(uuid())
  companyId         String
  company           Company           @relation(fields: [companyId], references: [id])
  name              String
  code              String
  startTime         String
  endTime           String
  gracePeriodMins   Int               @default(0)
  halfDayHours      Float             @default(4)
  minWorkingHours   Float             @default(8)
  isFlexible        Boolean           @default(false)
  isNightShift      Boolean           @default(false)
  isActive          Boolean           @default(true)
  shiftAssignments  ShiftAssignment[]
  attendances       Attendance[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@unique([companyId, code])
  @@index([companyId])
  @@map("shifts")
}

model ShiftAssignment {
  id         String    @id @default(uuid())
  employeeId String
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shiftId    String
  shift      Shift     @relation(fields: [shiftId], references: [id])
  effectiveFrom DateTime
  effectiveTo   DateTime?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([employeeId, shiftId, effectiveFrom])
  @@index([employeeId])
  @@index([shiftId])
  @@map("shift_assignments")
}

model Attendance {
  id             String            @id @default(uuid())
  employeeId     String
  employee       Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  companyId      String
  date           DateTime          @db.Date
  shiftId        String?
  shift          Shift?            @relation(fields: [shiftId], references: [id])
  clockIn        DateTime?
  clockOut       DateTime?
  clockInIp      String?
  clockOutIp     String?
  clockInLocation Json?
  clockOutLocation Json?
  clockInPhoto   String?
  clockOutPhoto  String?
  breakStart     DateTime?
  breakEnd       DateTime?
  totalBreakMins Int?
  totalHours     Float?
  overtimeHours  Float?
  status         AttendanceStatus @default(PENDING)
  remarks        String?
  regularizations AttendanceRegularization[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([companyId])
  @@index([date])
  @@map("attendances")
}

model AttendancePolicy {
  id                    String   @id @default(uuid())
  companyId             String   @unique
  company               Company  @relation(fields: [companyId], references: [id])
  allowLateArrival      Boolean  @default(true)
  gracePeriodMins       Int      @default(0)
  allowEarlyDeparture   Boolean  @default(true)
  earlyDepartureMins    Int      @default(0)
  halfDayHours          Float    @default(4)
  minWorkingHours       Float    @default(8)
  allowOvertime         Boolean  @default(false)
  maxOvertimeHoursDay   Float    @default(4)
  deductSalaryForLate   Boolean  @default(false)
  lateArrivalDeductPerc Float    @default(0)
  requirePhotoCapture   Boolean  @default(false)
  requireGpsLocation    Boolean  @default(false)
  requireIpRestriction  Boolean  @default(false)
  allowedIps            String[]
  weeklyOff1            String    @default("SUNDAY")
  weeklyOff2            String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("attendance_policies")
}

model AttendanceRegularization {
  id           String               @id @default(uuid())
  attendanceId String
  attendance   Attendance           @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  employeeId   String
  requestedClockIn DateTime?
  requestedClockOut DateTime?
  reason       String
  status       RegularizationStatus @default(PENDING)
  reviewedBy   String?
  reviewedAt   DateTime?
  reviewRemarks String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([attendanceId])
  @@index([employeeId])
  @@index([status])
  @@map("attendance_regularizations")
}

enum AttendanceStatus {
  PENDING
  PRESENT
  ABSENT
  HALF_DAY
  LATE
  ON_LEAVE
  HOLIDAY
  WEEK_OFF
}

enum RegularizationStatus {
  PENDING
  APPROVED
  REJECTED
}

// ========================================
// LEAVE TYPES & CONFIGURATION
// ========================================

// Leave Category Enum
enum LeaveCategory {
  CASUAL
  SICK
  PRIVILEGE
  MATERNITY
  PATERNITY
  BEREAVEMENT
  UNPAID
  COMP_OFF
  WORK_FROM_HOME
}

// Accrual Type
enum AccrualType {
  MONTHLY
  YEARLY
}

// Session Type (for half-day support)
enum SessionType {
  FULL_DAY
  FIRST_HALF
  SECOND_HALF
}

// Approval Status
enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  MODIFICATION_REQUESTED
}

// Approval Role
enum ApprovalRole {
  MANAGER
  HR
  BOTH
}

// Leave Type Configuration (company-specific)
model LeaveTypeConfig {
  id              String        @id @default(uuid())
  companyId       String
  company         Company       @relation(fields: [companyId], references: [id])
  
  name            String
  code            String
  type            LeaveCategory
  
  annualDays      Int           @default(0)
  isActive        Boolean       @default(true)
  
  accrualType     AccrualType   @default(YEARLY)
  accrualRate     Float         @default(0)
  
  maxConsecutive  Int           @default(0)
  minNoticeDays   Int           @default(0)
  canApplyHalfDay Boolean       @default(true)
  maxHalfDaysPerYear Int        @default(0)
  
  genderSpecific  Gender?
  
  allowCarryForward Boolean     @default(false)
  maxCarryForward  Int           @default(0)
  
  allowEncashment  Boolean       @default(false)
  maxEncashDays    Int           @default(0)
  
  expiryDays       Int           @default(0)
  
  sortOrder        Int           @default(0)
  
  // Reverse relations
  leaveApplications LeaveApplication[]
  leaveBalances    LeaveBalance[]
  
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@unique([companyId, code])
  @@index([companyId])
  @@map("leave_type_configs")
}

// ========================================
// LEAVE POLICY (Company-wide)
// ========================================

model LeavePolicy {
  id                    String        @id @default(uuid())
  companyId             String        @unique
  company               Company       @relation(fields: [companyId], references: [id])
  
  approvalLevel1       ApprovalRole  @default(MANAGER)
  approvalLevel2       ApprovalRole?
  managerApprovalDays  Int           @default(2)
  hrApprovalDays       Int           @default(3)
  
  encashmentStartMonth Int           @default(1)
  encashmentEndMonth   Int           @default(3)
  
  processCarryForward  Boolean       @default(true)
  carryForwardDeadline DateTime?
  
  allowAutoApproval    Boolean       @default(false)
  autoApprovalDaysThreshold Int      @default(0)
  
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@map("leave_policies")
}

// Leave Types Enum (Legacy - for backward compatibility)
enum LeaveType {
  CASUAL
  SICK
  PRIVILEGE
  MATERNITY
  PATERNITY
  BEREAVEMENT
  UNPAID
  WORK_FROM_HOME
}

// Leave Request Status
enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

// ========================================
// LEAVE APPLICATION (with half-day & multi-level approval)
// ========================================

model LeaveApplication {
  id                String          @id @default(uuid())
  employeeId        String
  employee          Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  companyId         String
  company           Company         @relation(fields: [companyId], references: [id])
  
  // Reference to leave type config (new) or legacy leaveType
  leaveTypeId       String?
  leaveTypeConfig   LeaveTypeConfig? @relation(fields: [leaveTypeId], references: [id])
  leaveType         LeaveType? // Legacy field
  
  // Leave details
  startDate         DateTime        @db.Date
  endDate           DateTime        @db.Date
  startSession      SessionType     @default(FULL_DAY)
  endSession        SessionType     @default(FULL_DAY)
  totalDays         Float
  
  reason            String?
  attachmentUrl     String?
  
  // Status
  status            LeaveStatus     @default(PENDING)
  
  // Level 1 approval (Manager)
  level1Status      ApprovalStatus  @default(PENDING)
  level1ReviewedBy  String?
  level1ReviewedAt  DateTime?
  level1Remarks     String?
  
  // Level 2 approval (HR)
  level2Status      ApprovalStatus? 
  level2ReviewedBy  String?
  level2ReviewedAt  DateTime?
  level2Remarks     String?
  
  // Current approver
  currentApproverLevel Int           @default(1)
  approverId         String?
  
  // Cancellation
  isCancelled       Boolean         @default(false)
  cancelledAt        DateTime?
  cancelledBy        String?
  
  // Relations for comments and approval history
  comments          LeaveComment[]
  approvalHistory   LeaveApprovalHistory[]
  
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([employeeId, startDate])
  @@index([companyId])
  @@index([employeeId])
  @@index([status])
  @@index([leaveTypeId])
  @@map("leave_applications")
}

// ========================================
// LEAVE BALANCE (with accrual tracking)
// ========================================

model LeaveBalance {
  id                String          @id @default(uuid())
  employeeId        String
  employee          Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  companyId         String
  company           Company         @relation(fields: [companyId], references: [id])
  
  // Reference to leave type config (new) or legacy leaveType
  leaveTypeId       String?
  leaveTypeConfig   LeaveTypeConfig? @relation(fields: [leaveTypeId], references: [id])
  leaveType         LeaveType? // Legacy field
  
  year              Int
  month             Int?
  
  allocatedDays     Float           @default(0)
  accruedDays       Float           @default(0)
  carriedForward    Float           @default(0)
  
  usedDays          Float           @default(0)
  pendingDays       Float           @default(0)
  availableDays     Float
  
  encashedDays      Float           @default(0)
  expiredDays       Float           @default(0)
  lastAccruedAt     DateTime?
  
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@unique([employeeId, year, leaveTypeId])
  @@unique([employeeId, year, leaveType]) // Legacy
  @@index([employeeId])
  @@index([companyId])
  @@map("leave_balances")
}

// ========================================
// COMPENSATORY OFF (COMP-OFF)
// ========================================

enum CompOffStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
  USED
  CANCELLED
}

model CompOffRequest {
  id                String        @id @default(uuid())
  companyId         String
  company           Company       @relation(fields: [companyId], references: [id])
  
  employeeId        String
  employee          Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  workDate          DateTime      @db.Date
  workSession       SessionType   @default(FULL_DAY)
  
  expiryDate        DateTime?
  isUsed            Boolean       @default(false)
  usedOnDate        DateTime?
  
  reason            String?
  attachmentUrl     String?
  approvedBy        String?
  approvedAt        DateTime?
  
  status            CompOffStatus @default(PENDING)
  
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@unique([employeeId, workDate])
  @@index([companyId])
  @@index([employeeId])
  @@map("comp_off_requests")
}

model CompOffBalance {
  id                String   @id @default(uuid())
  employeeId        String
  employee          Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  companyId         String
  company           Company  @relation(fields: [companyId], references: [id])
  
  earnedDays        Float    @default(0)
  usedDays          Float    @default(0)
  availableDays     Float
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([employeeId])
  @@index([employeeId])
  @@map("comp_off_balances")
}

// ========================================
// HOLIDAYS (with location support)
// ========================================

model Holiday {
  id              String        @id @default(uuid())
  companyId       String
  company         Company       @relation(fields: [companyId], references: [id])
  
  name            String
  date            DateTime      @db.Date
  description     String?
  
  branchId        String?
  branch          Branch?       @relation(fields: [branchId], references: [id])
  
  isOptional      Boolean       @default(false)
  isRecurring     Boolean       @default(true)
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([companyId, date, branchId])
  @@index([companyId])
  @@index([branchId])
  @@map("holidays")
}

// Legacy Leave Holiday (to be replaced)
model LeaveHoliday {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  
  name        String
  date        DateTime @db.Date
  isOptional  Boolean  @default(false)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([companyId, date])
  @@index([companyId])
  @@map("leave_holidays")
}

// ========================================
// LEAVE COMMENTS & COMMUNICATION
// ========================================

model LeaveComment {
  id          String   @id @default(uuid())
  applicationId String
  application LeaveApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  
  comment     String
  isInternal  Boolean  @default(false)
  
  createdAt   DateTime @default(now())

  @@index([applicationId])
  @@map("leave_comments")
}

// ========================================
// LEAVE NOTIFICATIONS
// ========================================

enum NotificationType {
  LEAVE_APPLIED
  LEAVE_APPROVED
  LEAVE_REJECTED
  LEAVE_MODIFICATION_REQUESTED
  LEAVE_CANCELLED
  BALANCE_LOW
  COMP_OFF_EARNED
  COMP_OFF_EXPIRING
  COMP_OFF_APPLIED
  COMP_OFF_APPROVED
  COMP_OFF_REJECTED
}

model LeaveNotification {
  id            String          @id @default(uuid())
  companyId     String
  company       Company         @relation(fields: [companyId], references: [id])
  
  employeeId    String
  type          NotificationType
  
  title         String
  message       String
  
  relatedType   String?
  relatedId     String?
  
  isRead        Boolean         @default(false)
  readAt        DateTime?
  
  createdAt     DateTime        @default(now())

  @@index([employeeId])
  @@index([companyId])
  @@map("leave_notifications")
}

// ========================================
// LEAVE APPROVAL HISTORY
// ========================================

model LeaveApprovalHistory {
  id            String   @id @default(uuid())
  applicationId String
  application   LeaveApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  
  approverId    String
  approver      User     @relation(fields: [approverId], references: [id])
  level         Int
  
  action        String
  comments      String?
  
  createdAt     DateTime @default(now())

  @@index([applicationId])
  @@map("leave_approval_history")
}
