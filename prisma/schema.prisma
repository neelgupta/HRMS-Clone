generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id                   String                @id @default(uuid())
  name                 String
  status               CompanyStatus         @default(PENDING)
  logoUrl              String?
  iconUrl              String?
  industry             String?
  registrationNumber   String?
  panNumber            String?
  tanNumber            String?
  gstNumber            String?
  startDate            DateTime?
  fiscalYearStart      DateTime?
  fiscalYearEnd        DateTime?
  primaryEmail         String?
  primaryPhone         String?
  website              String?
  setupCompleted       Boolean               @default(false)
  addresses            CompanyAddress[]
  branches             Branch[]
  bankDetail           BankDetail?
  generalSetting       GeneralSetting?
  employeeCustomFields EmployeeCustomField[]
  users                User[]
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@map("companies")
}

model User {
  id          String               @id @default(uuid())
  name        String
  email       String               @unique
  phone       String
  password    String
  role        Role                 @default(HR_ADMIN)
  status      UserStatus           @default(INACTIVE)
  companyId   String
  branchId    String?
  branch      Branch?              @relation(fields: [branchId], references: [id])
  company     Company              @relation(fields: [companyId], references: [id])
  resetTokens PasswordResetToken[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@map("users")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}

model CompanyAddress {
  id           String      @id @default(uuid())
  companyId    String
  company      Company     @relation(fields: [companyId], references: [id])
  type         AddressType
  label        String?
  addressLine1 String
  addressLine2 String?
  city         String
  state        String
  country      String
  pincode      String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@map("company_addresses")
}

model Branch {
  id           String   @id @default(uuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id])
  name         String
  contactEmail String?
  contactPhone String?
  addressLine1 String
  addressLine2 String?
  city         String
  state        String
  country      String
  pincode      String
  users        User[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("branches")
}

model BankDetail {
  id                String   @id @default(uuid())
  companyId         String   @unique
  company           Company  @relation(fields: [companyId], references: [id])
  bankName          String
  accountHolderName String
  accountNumber     String
  ifscCode          String
  branchName        String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("bank_details")
}

model GeneralSetting {
  id                 String       @id @default(uuid())
  companyId          String       @unique
  company            Company      @relation(fields: [companyId], references: [id])
  currency           String       @default("INR")
  dateFormat         String       @default("DD/MM/YYYY")
  timeZone           String       @default("Asia/Kolkata")
  workweek           WorkweekType @default(MON_FRI)
  holidayList        DateTime[]
  emailNotifications Boolean      @default(true)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@map("general_settings")
}

model EmployeeCustomField {
  id        String          @id @default(uuid())
  companyId String
  company   Company         @relation(fields: [companyId], references: [id])
  fieldName String
  fieldType CustomFieldType
  required  Boolean         @default(false)
  options   String[]
  sortOrder Int             @default(0)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@map("employee_custom_fields")
}

enum Role {
  SUPER_ADMIN
  HR_ADMIN
  PAYROLL_MANAGER
  DEPT_MANAGER
  EMPLOYEE
}

enum CompanyStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum UserStatus {
  INACTIVE
  ACTIVE
}

enum AddressType {
  HEAD_OFFICE
  BRANCH
}

enum WorkweekType {
  MON_FRI
  MON_SAT
}

enum CustomFieldType {
  TEXT
  NUMBER
  DATE
  DROPDOWN
  CHECKBOX
}
